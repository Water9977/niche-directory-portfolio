---
interface Props {
  slug: string;
  displayName: string;
  city: string;
  state: string;
  rating: number | null;
  pricingMin: number | null;
  pricingPeriod: string;
  pricingNote: string | null;
  stallsCount: number | null;
  climateControlled: boolean;
  adaCompliant: boolean;
}

const {
  slug,
  displayName,
  city,
  state,
  rating,
  pricingMin,
  pricingPeriod,
  pricingNote,
  stallsCount,
  climateControlled,
  adaCompliant
} = Astro.props;

const formatCost = (cost: number) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    maximumFractionDigits: 0
  }).format(cost);
};
---

<div class="facility-card animate-fade-in">
  <div class="card-header">
    <span class="card-location">{city}, {state.toUpperCase()}</span>
    {rating && (
      <span class="card-rating">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
        </svg>
        {rating.toFixed(1)}
      </span>
    )}
  </div>
  
  <div class="card-body">
    <h3 class="card-title">
      <a href={`/suppliers/${slug}`}>{displayName}</a>
    </h3>
    
    <div class="card-pricing">
      {pricingMin ? (
        <div>
          <span class="pricing-label">Starting at</span>
          <span class="pricing-amount">{formatCost(pricingMin)}</span>
          <span class="pricing-period">/{pricingPeriod.replace(/_/g, ' ')}</span>
        </div>
      ) : (
        <span class="pricing-missing">Contact for event pricing quote</span>
      )}
    </div>

    <div class="card-details">
      {stallsCount && (
        <div class="detail-item">
          <strong>Stalls:</strong> {stallsCount} Station Trailer
        </div>
      )}
    </div>

    <div class="card-badges">
      {climateControlled && (
        <span class="badge badge-success">
          Climate Controlled
        </span>
      )}
      {adaCompliant && (
        <span class="badge badge-primary">
          ADA Accessible
        </span>
      )}
    </div>
  </div>
  
  <div class="card-footer">
    <a href={`/suppliers/${slug}`} class="btn btn-outline card-btn">Details & Quote</a>
  </div>
</div>

<style>
  .facility-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: var(--transition);
  }

  .facility-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xs);
  }

  .card-location {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .card-rating {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--accent);
  }

  .card-title {
    font-size: 1.2rem;
    margin-bottom: var(--space-sm);
  }

  .card-title a {
    color: var(--text-main);
  }

  .card-title a:hover {
    color: var(--accent);
  }

  .card-pricing {
    margin-bottom: var(--space-md);
  }

  .pricing-label {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .pricing-amount {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--primary);
  }

  .pricing-period {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .pricing-missing {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .card-details {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: var(--space-sm);
  }

  .card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: auto;
    margin-bottom: var(--space-md);
  }

  .card-footer {
    border-top: 1px solid var(--border);
    padding-top: var(--space-md);
    margin-top: auto;
  }

  .card-btn {
    width: 100%;
    text-align: center;
  }
</style>
