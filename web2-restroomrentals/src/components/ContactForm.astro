---
interface Props {
  facilityName?: string;
}

const { facilityName } = Astro.props;
---

<div class="contact-form-container">
  <div class="form-header">
    <h3>Request Rental Quote</h3>
    <p>Compare luxury portable toilets, restroom trailers, and quote deliveries for your event with {facilityName || 'this company'}.</p>
  </div>
  
  <form class="contact-form" action="#" method="POST" id="leadForm">
    {facilityName && (
      <input type="hidden" name="vendor" value={facilityName} />
    )}
    
    <div class="form-group">
      <label for="name">Contact Name *</label>
      <input type="text" id="name" name="name" required placeholder="Jane Smith" />
    </div>

    <div class="form-group mt-sm-row">
      <div class="half-width">
        <label for="phone">Phone Number *</label>
        <input type="tel" id="phone" name="phone" required placeholder="(555) 555-5555" />
      </div>
      <div class="half-width">
        <label for="email">Email *</label>
        <input type="email" id="email" name="email" required placeholder="jane@example.com" />
      </div>
    </div>

    <div class="form-group mt-sm-row">
      <div class="half-width">
        <label for="eventDate">Event Date *</label>
        <input type="date" id="eventDate" name="eventDate" required />
      </div>
      <div class="half-width">
        <label for="guests">Expected Guests *</label>
        <input type="number" id="guests" name="guests" required min="10" placeholder="e.g. 150" />
      </div>
    </div>

    <div class="form-group">
      <label for="eventType">Event Type</label>
      <select id="eventType" name="eventType">
        <option value="wedding">Wedding Ceremony</option>
        <option value="corporate">Corporate Outing</option>
        <option value="outdoor">Outdoor Festival/Concert</option>
        <option value="private">Private Party</option>
        <option value="construction">Construction/Commercial Site</option>
      </select>
    </div>

    <div class="form-group">
      <label for="message">Rental details or special requirements</label>
      <textarea id="message" name="message" rows="3" placeholder="Do you require ADA-compliant trailers, multi-day rentals, or specific hookup connections?"></textarea>
    </div>

    <button type="submit" class="btn btn-primary btn-submit">Request Free Quote</button>
  </form>
</div>

<style>
  .contact-form-container {
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    position: sticky;
    top: 90px;
  }

  .form-header {
    background-color: var(--primary);
    color: #ffffff;
    padding: var(--space-md) var(--space-lg);
    border-bottom: 2px solid var(--accent);
  }

  .form-header h3 {
    color: #ffffff;
    font-size: 1.15rem;
    margin-bottom: var(--space-2xs);
  }

  .form-header p {
    color: #cbd5e0;
    font-size: 0.85rem;
    line-height: 1.35;
  }

  .contact-form {
    padding: var(--space-lg);
  }

  .form-group {
    margin-bottom: var(--space-md);
  }

  .mt-sm-row {
    display: flex;
    gap: var(--space-md);
  }

  .half-width {
    flex: 1;
  }

  .form-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: var(--space-2xs);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.65rem var(--space-sm);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--text-main);
    background-color: var(--bg-page);
    transition: var(--transition);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent);
    background-color: #ffffff;
    box-shadow: 0 0 0 3px var(--primary-light);
  }

  .btn-submit {
    width: 100%;
    padding: 0.85rem;
    font-size: 1rem;
    margin-top: var(--space-xs);
  }
</style>
