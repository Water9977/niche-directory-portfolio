---
interface Props {
  city: string;
  state: string;
  deliveryRadiusMiles: number;
}

const { city, state, deliveryRadiusMiles = 50 } = Astro.props;
---

<div class="delivery-map-container">
  <h4>Delivery Area & Pricing Map</h4>
  <div class="map-visual">
    <div class="center-pin">📍</div>
    <div class="radius-circle" style={`--radius-pct: 60%`}></div>
    <div class="radius-label">{deliveryRadiusMiles} Mile Free Delivery Zone</div>
  </div>
  
  <div class="delivery-pricing">
    <div class="pricing-tier">
      <span class="tier-range">0 - {deliveryRadiusMiles} Miles:</span>
      <span class="tier-cost text-success">FREE Delivery & Setup</span>
    </div>
    <div class="pricing-tier">
      <span class="tier-range">{deliveryRadiusMiles} - 100 Miles:</span>
      <span class="tier-cost">$2.50 per mile (calculated one-way)</span>
    </div>
    <div class="pricing-tier">
      <span class="tier-range">100+ Miles:</span>
      <span class="tier-cost">Custom long-distance transport rates apply</span>
    </div>
  </div>
  <p class="delivery-note">Note: Supplier is based in the {city}, {state.toUpperCase()} area. Weekend drop-offs occur on Friday with pickup on Monday.</p>
</div>

<style>
  .delivery-map-container {
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    margin-bottom: var(--space-lg);
  }
  .delivery-map-container h4 {
    margin-top: 0;
    margin-bottom: var(--space-sm);
    font-size: 1.05rem;
    color: var(--text-primary);
  }
  .map-visual {
    height: 160px;
    background-color: #e2e8f0;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-md);
    background-image: radial-gradient(#cbd5e1 1px, transparent 0);
    background-size: 12px 12px;
  }
  .center-pin {
    font-size: 1.5rem;
    z-index: 10;
  }
  .radius-circle {
    position: absolute;
    width: var(--radius-pct);
    height: var(--radius-pct);
    border: 2px dashed var(--color-success);
    background-color: rgba(16, 185, 129, 0.08);
    border-radius: 50%;
    animation: pulse 3s infinite ease-in-out;
  }
  .radius-label {
    position: absolute;
    bottom: var(--space-xs);
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 2px var(--space-sm);
    font-size: 0.75rem;
    font-weight: 600;
  }
  .delivery-pricing {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    font-size: 0.9rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: var(--space-sm);
    margin-bottom: var(--space-sm);
  }
  .pricing-tier {
    display: flex;
    justify-content: space-between;
  }
  .tier-range {
    color: var(--text-secondary);
    font-weight: 500;
  }
  .tier-cost {
    font-weight: 600;
    color: var(--text-primary);
  }
  .text-success {
    color: var(--text-success);
  }
  .delivery-note {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.3;
  }
  
  @keyframes pulse {
    0%, 100% {
      transform: scale(0.96);
      opacity: 0.85;
    }
    50% {
      transform: scale(1.04);
      opacity: 1;
    }
  }
</style>
