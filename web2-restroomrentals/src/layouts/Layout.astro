---
import '../styles/index.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  schemaMarkup?: string;
}

const { title, description, canonicalUrl, schemaMarkup } = Astro.props;

const siteUrl = "https://restroomtrailers.directory";
const currentUrl = canonicalUrl || siteUrl;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <link rel="canonical" href={currentUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/og-image.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={currentUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="/images/og-image.jpg" />

    {schemaMarkup && (
      <script type="application/ld+json" set:html={schemaMarkup}></script>
    )}
  </head>
  <body>
    <header class="navbar">
      <div class="container navbar-container">
        <a href="/" class="logo">
          Restroom<span>Rentals</span>
        </a>
        <nav>
          <ul class="nav-links">
            <li><a href="/" class="nav-link">Home</a></li>
            <li><a href="/tx/mckinney" class="nav-link">McKinney, TX</a></li>
            <li><a href="/tn/franklin" class="nav-link">Franklin, TN</a></li>
            <li><a href="/nc/huntersville" class="nav-link">Huntersville, NC</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <h3>RestroomRentals</h3>
            <p>Direct comparison of luxury restroom trailers, ADA units, and portable sanitation options for premium events.</p>
          </div>
          <div class="footer-nav">
            <h4>Locations</h4>
            <ul>
              <li><a href="/tx/mckinney">McKinney, TX</a></li>
              <li><a href="/tn/franklin">Franklin, TN</a></li>
              <li><a href="/nc/huntersville">Huntersville, NC</a></li>
            </ul>
          </div>
          <div class="footer-nav">
            <h4>Information</h4>
            <ul>
              <li><a href="/#about">Trailer Specs</a></li>
              <li><a href="/#faq">Rates & Booking</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} RestroomRentals. All rights reserved.</p>
          <p>Verified Event Sanitation Directories</p>
        </div>
      </div>
    </footer>
  </body>
</html>
