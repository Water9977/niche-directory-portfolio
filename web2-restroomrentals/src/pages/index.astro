---
import Layout from '../layouts/Layout.astro';
import listings from '../data/listings.json';
import Card from '../components/Card.astro';
import FAQ from '../components/FAQ.astro';

const states = [
  { name: 'Texas', code: 'tx', cities: ['McKinney', 'Richardson', 'Frisco', 'Georgetown', 'Leander', 'Wimberley'] },
  { name: 'Tennessee', code: 'tn', cities: ['Franklin', 'Brentwood', 'Murfreesboro', 'Nolensville'] },
  { name: 'North Carolina', code: 'nc', cities: ['Huntersville', 'Cornelius', 'Weddington'] }
];

const getCityCount = (city: string, state: string) => {
  return listings.filter(l => l.city.toLowerCase() === city.toLowerCase() && l.state.toLowerCase() === state.toLowerCase()).length;
};

const featuredListings = listings.filter(l => l.rating && l.rating >= 4.5).slice(0, 3);

const faqItems = [
  {
    question: "How much does a luxury restroom trailer cost to rent?",
    answer: "Luxury restroom trailer rentals typically range from $750 to $2,500 per event day. The final cost depends on the trailer size (2-stall to 10-stall units), climate control features, event duration, delivery distance, and whether on-site attendants or generator power are required."
  },
  {
    question: "Do luxury restroom trailers require water and electric hookups?",
    answer: "Most luxury trailers require a standard garden hose connection for water and at least one or two dedicated 110V/20A electrical outlets. However, if utilities are unavailable, many companies offer self-contained water tanks and generator rentals at an additional charge."
  },
  {
    question: "What is the delivery radius for restroom trailer companies?",
    answer: "Most local rental companies deliver within a 50 to 75-mile radius from their depot without extra mileage surcharges. For events further out, delivery fees are calculated per mile, usually ranging from $1.50 to $3.00 per round-trip mile."
  }
];
---

<Layout
  title="Restroom Rentals — Luxury Event Portable Restrooms & Trailer Pricing"
  description="Compare local luxury restroom trailers, portable toilet rentals, and event sanitation options with verified specs and guest capacities."
>
  <!-- Hero Section -->
  <section class="hero section">
    <div class="container hero-container">
      <div class="hero-content animate-fade-in">
        <span class="hero-tag">Verified Event Services</span>
        <h1>Compare Luxury Restroom Trailers Side-by-Side</h1>
        <p>Planning a wedding, corporate event, or festival? RestroomRentals tracks local portable restroom trailer providers, stall configurations, ADA units, and estimated delivery zones so you can secure quotes in minutes.</p>
        <div class="hero-actions">
          <a href="#browse" class="btn btn-primary">Browse Directories</a>
          <a href="#about" class="btn btn-outline">Trailer Configurations</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Finder Section -->
  <section id="finder" class="section finder-section" style="background-color: var(--secondary); border-bottom: 1px solid var(--border)">
    <div class="container">
      <h2 class="section-title">Interactive Trailer Finder</h2>
      <p class="section-subtitle">Filter local luxury restroom suppliers dynamically by guest capacity, climate control, or ADA compliance.</p>
      
      <div class="filter-controls">
        <div class="filter-group">
          <h5>Required Event Capacity</h5>
          <div class="checkbox-row">
            <label><input type="radio" name="filter-stalls" value="0" checked /> Any Size</label>
            <label><input type="radio" name="filter-stalls" value="2" /> 2+ Stalls (Up to 150 guests)</label>
            <label><input type="radio" name="filter-stalls" value="3" /> 3+ Stalls (Up to 250 guests)</label>
            <label><input type="radio" name="filter-stalls" value="5" /> 5+ Stalls (Up to 500 guests)</label>
          </div>
        </div>
        
        <div class="filter-group">
          <h5>Premium Features</h5>
          <div class="checkbox-row">
            <label><input type="checkbox" id="filter-climate" /> Climate Controlled</label>
            <label><input type="checkbox" id="filter-ada" /> ADA Accessible</label>
            <label><input type="checkbox" id="filter-water" /> Running Water Sinks</label>
          </div>
        </div>
      </div>
      
      <div class="grid grid-3" id="suppliers-grid" style="margin-top: var(--space-xl)">
        <!-- Rendered dynamically by JS -->
      </div>
      
      <div class="no-results-msg" id="no-results-msg" style="display: none; text-align: center; padding: var(--space-xl); border: 1px dashed var(--border); border-radius: var(--radius-md); background: var(--bg-card)">
        <p style="margin: 0; color: var(--text-muted); font-weight: 600">No restroom suppliers match your exact criteria. Try widening your capacity options!</p>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ listings }}>
    document.addEventListener('DOMContentLoaded', () => {
      const grid = document.getElementById('suppliers-grid');
      const noResults = document.getElementById('no-results-msg');
      
      const filterStalls = document.getElementsByName('filter-stalls');
      const filterClimate = document.getElementById('filter-climate');
      const filterAda = document.getElementById('filter-ada');
      const filterWater = document.getElementById('filter-water');
      
      const formatCost = (amount) => {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          maximumFractionDigits: 0
        }).format(amount);
      };
      
      const renderCards = (items) => {
        grid.innerHTML = '';
        if (items.length === 0) {
          noResults.style.display = 'block';
          return;
        }
        noResults.style.display = 'none';
        
        items.forEach(item => {
          const card = document.createElement('div');
          card.className = 'facility-card';
          
          const ratingBlock = item.rating 
            ? `<span class="card-rating" style="display:flex; align-items:center; gap:2px; font-weight:600; font-size:0.85rem">
                 ⭐ ${item.rating.toFixed(1)}
               </span>`
            : '';
            
          const pricingBlock = item.pricingMin
            ? `<div>
                 <span class="pricing-label" style="font-size:0.75rem; color:var(--text-muted)">Starting at</span>
                 <span class="pricing-amount" style="font-size:1.15rem; font-weight:700; color:var(--primary)">${formatCost(item.pricingMin)}</span>
                 <span class="pricing-period" style="font-size:0.75rem; color:var(--text-muted)">/${item.pricingPeriod.replace(/_/g, ' ')}</span>
               </div>`
            : `<span class="pricing-missing" style="font-size:0.85rem; color:var(--text-muted)">Contact for event pricing quote</span>`;
            
          card.innerHTML = `
            <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:var(--space-md); border-bottom:1px solid var(--border); padding-bottom:var(--space-xs)">
              <span class="card-location" style="font-size:0.8rem; font-weight:700; color:var(--text-muted); text-transform:uppercase">${item.city}, ${item.state.toUpperCase()}</span>
              ${ratingBlock}
            </div>
            <div class="card-body" style="display:flex; flex-direction:column; gap:var(--space-sm); flex-grow:1">
              <h3 class="card-title" style="margin:0; font-size:1.15rem">
                <a href="/suppliers/${item.slug}" style="color:var(--text-main); font-weight:700">${item.displayName}</a>
              </h3>
              <div class="card-pricing" style="margin-bottom:var(--space-xs)">
                ${pricingBlock}
              </div>
              
              <div class="card-details" style="font-size:0.85rem; color:var(--text-muted)">
                <strong>Stalls:</strong> ${item.nicheFields.stallsCount ? `${item.nicheFields.stallsCount} Station Trailer` : 'Varies'}
              </div>
              
              <div class="card-badges" style="display:flex; gap:var(--space-xs); flex-wrap:wrap">
                ${item.nicheFields.climateControlled ? '<span class="badge badge-success" style="background:#10b981; color:white; padding:2px 8px; border-radius:50px; font-size:0.75rem; font-weight:600">Climate Ctrl</span>' : ''}
                ${item.nicheFields.adaCompliant ? '<span class="badge badge-primary" style="background:#3b82f6; color:white; padding:2px 8px; border-radius:50px; font-size:0.75rem; font-weight:600">♿ ADA</span>' : ''}
                ${item.nicheFields.hasRunningWater ? '<span class="badge badge-outline" style="border:1px solid var(--border); color:var(--text-main); padding:2px 8px; border-radius:50px; font-size:0.75rem; font-weight:600">Sinks</span>' : ''}
              </div>
            </div>
            <div class="card-footer" style="margin-top:var(--space-lg)">
              <a href="/suppliers/${item.slug}" class="btn btn-outline" style="width:100%; text-align:center; display:block">Details & Quote</a>
            </div>
          `;
          grid.appendChild(card);
        });
      };
      
      const filterListings = () => {
        let filtered = listings;
        
        let minStalls = 0;
        for (const radio of filterStalls) {
          if (radio.checked) {
            minStalls = parseInt(radio.value);
            break;
          }
        }
        
        if (minStalls > 0) {
          filtered = filtered.filter(item => (item.nicheFields.stallsCount || 0) >= minStalls);
        }
        
        if (filterClimate.checked) {
          filtered = filtered.filter(item => item.nicheFields.climateControlled === true);
        }
        if (filterAda.checked) {
          filtered = filtered.filter(item => item.nicheFields.adaCompliant === true);
        }
        if (filterWater.checked) {
          filtered = filtered.filter(item => item.nicheFields.hasRunningWater === true);
        }
        
        renderCards(filtered);
      };
      
      [filterClimate, filterAda, filterWater].forEach(checkbox => {
        checkbox.addEventListener('change', filterListings);
      });
      
      filterStalls.forEach(radio => {
        radio.addEventListener('change', filterListings);
      });
      
      renderCards(listings);
    });
  </script>

  <!-- Browse Section -->
  <section id="browse" class="section browse-section">
    <div class="container">
      <h2 class="section-title">Browse Rentals by State</h2>
      <p class="section-subtitle">Select a state and city to view verified event sanitation providers and trailer specifications.</p>
      
      <div class="grid grid-3">
        {states.map(state => (
          <div class="state-card">
            <h3>{state.name}</h3>
            <div class="city-links">
              {state.cities.map(city => {
                const count = getCityCount(city, state.code);
                const href = `/${state.code}/${city.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
                return (
                  <a href={href} class="city-link">
                    <span class="city-name">{city}</span>
                    <span class="city-count">{count} {count === 1 ? 'listing' : 'listings'}</span>
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Section -->
  {featuredListings.length > 0 && (
    <section class="section featured-section">
      <div class="container">
        <h2 class="section-title">Top Rated Event Rental Providers</h2>
        <p class="section-subtitle">Highly reviewed sanitation specialists featuring luxury wedding trailers and responsive customer support.</p>
        
        <div class="grid grid-3">
          {featuredListings.map(item => (
            <Card
              slug={item.slug}
              displayName={item.displayName}
              city={item.city}
              state={item.state}
              rating={item.rating}
              pricingMin={item.pricingMin}
              pricingPeriod={item.pricingPeriod}
              pricingNote={item.pricingNote}
              stallsCount={item.nicheFields.stallsCount}
              climateControlled={item.nicheFields.climateControlled}
              adaCompliant={item.nicheFields.adaCompliant}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Specifications Info Section -->
  <section id="about" class="section info-section">
    <div class="container">
      <div class="info-grid">
        <div class="info-content">
          <h2>Luxury Restroom Specifications</h2>
          <p>Standard construction portapotties aren't suitable for upscale events. Our directory rates luxury trailers based on several premium criteria:</p>
          <ul class="info-list">
            <li>
              <strong>Stall Stations:</strong> Compare sizes ranging from 2-stall trailers (up to 150 guests) to 10-stall trailers (up to 750 guests) to match your guest count.
            </li>
            <li>
              <strong>Climate Control:</strong> Verified air-conditioning and heaters to ensure guest comfort in extreme summer heat or winter cold.
            </li>
            <li>
              <strong>Running Water & Flush:</strong> All luxury trailers include hands-free flushing porcelain toilets and running water vanity sinks.
            </li>
          </ul>
        </div>
        <div class="info-card">
          <h4>Need a Custom Quote?</h4>
          <p>Rental rates fluctuate based on seasonal demand (especially wedding season from May to October). Select a listing and fill out the contact form to secure booking dates.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="section faq-section">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <p class="section-subtitle">Rates, logistics, and planning guidance for outdoor event restrooms.</p>
      <FAQ items={faqItems} />
    </div>
  </section>
</Layout>

<style>
  /* Hero Styles */
  .hero {
    background: linear-gradient(135deg, var(--primary-light) 0%, hsl(155, 60%, 98%) 100%);
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .hero-container {
    min-height: 480px;
    display: flex;
    align-items: center;
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  .hero-content {
    max-width: 780px;
  }

  .hero-tag {
    display: inline-block;
    background-color: var(--accent);
    color: var(--primary);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: var(--space-md);
  }

  .hero h1 {
    font-size: 3rem;
    color: var(--text-main);
    margin-bottom: var(--space-md);
    line-height: 1.15;
  }

  .hero p {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: var(--space-xl);
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* Section Headers */
  .section-title {
    font-size: 2.2rem;
    text-align: center;
    margin-bottom: var(--space-xs);
  }

  .section-subtitle {
    text-align: center;
    color: var(--text-muted);
    margin-bottom: var(--space-2xl);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Browse Cards */
  .state-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    box-shadow: var(--shadow-sm);
  }

  .state-card h3 {
    font-size: 1.35rem;
    margin-bottom: var(--space-lg);
    color: var(--primary);
    border-bottom: 2px solid var(--primary-light);
    padding-bottom: var(--space-xs);
  }

  .city-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .city-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm);
    border-radius: var(--radius-sm);
    background-color: var(--bg-page);
    border: 1px solid transparent;
  }

  .city-link:hover {
    border-color: var(--accent);
    background-color: var(--primary-light);
  }

  .city-name {
    font-weight: 600;
    color: var(--text-main);
  }

  .city-count {
    font-size: 0.8rem;
    color: var(--text-muted);
    background-color: var(--bg-card);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }

  /* Info Section */
  .info-section {
    background-color: var(--secondary);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .info-grid {
    display: grid;
    gap: var(--space-2xl);
    grid-template-columns: 1fr;
  }

  @media (min-width: 900px) {
    .info-grid {
      grid-template-columns: 2fr 1fr;
    }
  }

  .info-content h2 {
    font-size: 2rem;
    margin-bottom: var(--space-md);
  }

  .info-list {
    list-style: none;
    margin-top: var(--space-md);
  }

  .info-list li {
    margin-bottom: var(--space-md);
    position: relative;
    padding-left: var(--space-xl);
  }

  .info-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 2px;
    color: var(--accent);
    font-weight: 800;
    font-size: 1.1rem;
  }

  .info-card {
    background-color: var(--primary);
    color: #ffffff;
    padding: var(--space-xl);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-left: 4px solid var(--accent);
  }

  .info-card h4 {
    color: #ffffff;
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
  }

  .info-card p {
    color: #a0aec0;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 2.25rem;
    }
  }

  /* Filter Dashboard Styles */
  .filter-controls {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    margin-bottom: var(--space-lg);
    box-shadow: var(--shadow-sm);
  }
  @media (min-width: 768px) {
    .filter-controls {
      grid-template-columns: 1fr 1fr;
    }
  }
  .filter-group h5 {
    margin-top: 0;
    margin-bottom: var(--space-sm);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--primary);
  }
  .checkbox-row {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }
  .checkbox-row label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    cursor: pointer;
  }
  .checkbox-row input[type="checkbox"],
  .checkbox-row input[type="radio"] {
    width: 16px;
    height: 16px;
    cursor: pointer;
  }
</style>
