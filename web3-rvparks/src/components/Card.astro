---
interface Props {
  slug: string;
  displayName: string;
  city: string;
  state: string;
  rating: number | null;
  pricingMin: number | null;
  pricingPeriod: string;
  pricingNote: string | null;
  verizonSignal: string | null;
  tmobileSignal: string | null;
  attSignal: string | null;
  wifiAvailable: boolean;
  maxRvLengthFt: number | null;
}

const {
  slug,
  displayName,
  city,
  state,
  rating,
  pricingMin,
  pricingPeriod,
  pricingNote,
  verizonSignal,
  tmobileSignal,
  attSignal,
  wifiAvailable,
  maxRvLengthFt
} = Astro.props;

const formatCost = (cost: number) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    maximumFractionDigits: 0
  }).format(cost);
};
---

<div class="facility-card animate-fade-in">
  <div class="card-header">
    <span class="card-location">{city}, {state.toUpperCase()}</span>
    {rating && (
      <span class="card-rating">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
        </svg>
        {rating.toFixed(1)}
      </span>
    )}
  </div>
  
  <div class="card-body">
    <h3 class="card-title">
      <a href={`/parks/${slug}`}>{displayName}</a>
    </h3>
    
    <div class="card-pricing">
      {pricingMin ? (
        <div>
          <span class="pricing-label">Starting at</span>
          <span class="pricing-amount">{formatCost(pricingMin)}</span>
          <span class="pricing-period">/{pricingPeriod}</span>
        </div>
      ) : (
        <span class="pricing-missing">Contact for nightly/weekly rates</span>
      )}
    </div>

    <!-- Signal Strengths -->
    <div class="card-signals">
      <span class="signals-label">Signal Quality:</span>
      <div class="signals-grid">
        <div class="signal-row">
          <span class="carrier-name">Verizon:</span>
          <span class={`signal-status signal-${verizonSignal || 'none'}`}>
            {verizonSignal || 'unreported'}
          </span>
        </div>
        <div class="signal-row">
          <span class="carrier-name">T-Mobile:</span>
          <span class={`signal-status signal-${tmobileSignal || 'none'}`}>
            {tmobileSignal || 'unreported'}
          </span>
        </div>
      </div>
    </div>

    <div class="card-badges">
      {wifiAvailable && (
        <span class="badge badge-success">
          Wi-Fi Available
        </span>
      )}
      {maxRvLengthFt && (
        <span class="badge badge-primary">
          Fits Up To {maxRvLengthFt}ft
        </span>
      )}
    </div>
  </div>
  
  <div class="card-footer">
    <a href={`/parks/${slug}`} class="btn btn-outline card-btn">Signal Report</a>
  </div>
</div>

<style>
  .facility-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: var(--transition);
  }

  .facility-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--primary);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xs);
  }

  .card-location {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .card-rating {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--accent);
  }

  .card-title {
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
  }

  .card-title a {
    color: var(--text-main);
  }

  .card-title a:hover {
    color: var(--primary);
  }

  .card-pricing {
    margin-bottom: var(--space-md);
  }

  .pricing-label {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .pricing-amount {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--primary);
  }

  .pricing-period {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .pricing-missing {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .card-signals {
    margin-bottom: var(--space-md);
    border-top: 1px dashed var(--border);
    padding-top: var(--space-xs);
  }

  .signals-label {
    display: block;
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .signals-grid {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .signal-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
  }

  .carrier-name {
    color: var(--text-muted);
  }

  .signal-status {
    font-weight: 700;
    text-transform: capitalize;
  }

  .signal-strong { color: var(--success); }
  .signal-medium { color: var(--accent); }
  .signal-weak { color: #e53e3e; }
  .signal-none { color: var(--text-muted); }

  .card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: auto;
    margin-bottom: var(--space-md);
  }

  .card-footer {
    border-top: 1px solid var(--border);
    padding-top: var(--space-md);
    margin-top: auto;
  }

  .card-btn {
    width: 100%;
    text-align: center;
  }
</style>
