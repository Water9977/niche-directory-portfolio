---
import Layout from '../layouts/Layout.astro';
import listings from '../data/listings.json';
import Card from '../components/Card.astro';
import FAQ from '../components/FAQ.astro';

const states = [
  { name: 'Montana', code: 'mt', cities: ['West Glacier', 'Cooke City', 'Gardiner'] },
  { name: 'Utah', code: 'ut', cities: ['Moab', 'Springdale', 'Kanab'] },
  { name: 'Arizona', code: 'az', cities: ['Sedona', 'Tusayan', 'Valle'] },
  { name: 'Colorado', code: 'co', cities: ['Estes Park'] },
  { name: 'Tennessee', code: 'tn', cities: ['Pigeon Forge', 'Townsend'] },
  { name: 'Maine', code: 'me', cities: ['Bar Harbor'] },
  { name: 'South Dakota', code: 'sd', cities: ['Custer'] }
];

const getCityCount = (city: string, state: string) => {
  return listings.filter(l => l.city.toLowerCase() === city.toLowerCase() && l.state.toLowerCase() === state.toLowerCase()).length;
};

const featuredListings = listings.filter(l => l.rating && l.rating >= 4.5).slice(0, 3);

const faqItems = [
  {
    question: "Why is cell signal verified data so important for RV campgrounds?",
    answer: "Most national campground platforms rely on user reviews which are subjective and often outdated. Camp Connected tracks carrier-specific signal strengths (Verizon, T-Mobile, AT&T) alongside verified Wi-Fi speed reports to ensure remote workers and digital nomads can confidently attend Zoom calls and meet project deadlines."
  },
  {
    question: "Do these campgrounds support Starlink connectivity?",
    answer: "Yes, our detailed facility profile pages identify whether campsite locations have clear northern-sky access for Starlink or are obstructed by heavy forest cover. We also list on-site Wi-Fi capabilities."
  },
  {
    question: "What is the average nightly cost for an RV site with hookups?",
    answer: "Nightly rates for standard back-in sites with partial hookups (water & electric) start around $45 to $65. Premium pull-through sites featuring full hookups (50 Amp power, sewer, water) in popular national park gateways range from $85 to $130 per night during peak summer seasons."
  }
];
---

<Layout
  title="Camp Connected — RV Parks with Verified Cell Signal & Wi-Fi"
  description="Find RV campgrounds and national park gateway resorts with verified Verizon, T-Mobile, and AT&T signal strengths and Wi-Fi speeds."
>
  <!-- Hero Section -->
  <section class="hero section">
    <div class="container hero-container">
      <div class="hero-content animate-fade-in">
        <span class="hero-tag">Verified Connectivity</span>
        <h1>Never Lose Connection While Camping</h1>
        <p>Tired of checking into RV parks only to find zero cell bars and dead Wi-Fi? We compile carrier signal audits, Starlink clearances, and verified campground Wi-Fi speeds near national parks so you can work and travel smoothly.</p>
        <div class="hero-actions">
          <a href="#browse" class="btn btn-primary">Browse Campgrounds</a>
          <a href="#about" class="btn btn-outline">Our Connectivity Audits</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Finder Section -->
  <section id="finder" class="section finder-section" style="background-color: var(--secondary); border-bottom: 1px solid var(--border)">
    <div class="container">
      <h2 class="section-title">Interactive Nomad Finder</h2>
      <p class="section-subtitle">Filter campgrounds dynamically by verified cellular signal strength, Starlink clearance, or Wi-Fi availability.</p>
      
      <div class="filter-controls">
        <div class="filter-group">
          <h5>Cellular Carriers (Strong/Medium Signal)</h5>
          <div class="checkbox-row">
            <label><input type="checkbox" id="filter-verizon" /> Verizon</label>
            <label><input type="checkbox" id="filter-tmobile" /> T-Mobile</label>
            <label><input type="checkbox" id="filter-att" /> AT&T</label>
          </div>
        </div>
        
        <div class="filter-group">
          <h5>Wifi & Satellite Standards</h5>
          <div class="checkbox-row">
            <label><input type="checkbox" id="filter-wifi" /> Verified Wi-Fi Available</label>
            <label><input type="checkbox" id="filter-starlink" /> Starlink Friendly</label>
          </div>
        </div>
      </div>
      
      <div class="grid grid-3" id="campgrounds-grid" style="margin-top: var(--space-xl)">
        <!-- Rendered dynamically by JS -->
      </div>
      
      <div class="no-results-msg" id="no-results-msg" style="display: none; text-align: center; padding: var(--space-xl); border: 1px dashed var(--border); border-radius: var(--radius-md); background: var(--bg-card)">
        <p style="margin: 0; color: var(--text-muted); font-weight: 600">No campgrounds match your exact connectivity criteria. Try clearing some filters!</p>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ listings }}>
    document.addEventListener('DOMContentLoaded', () => {
      const grid = document.getElementById('campgrounds-grid');
      const noResults = document.getElementById('no-results-msg');
      
      const filterVerizon = document.getElementById('filter-verizon');
      const filterTMobile = document.getElementById('filter-tmobile');
      const filterAtt = document.getElementById('filter-att');
      const filterWifi = document.getElementById('filter-wifi');
      const filterStarlink = document.getElementById('filter-starlink');
      
      const formatCost = (amount) => {
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: 'USD',
          maximumFractionDigits: 0
        }).format(amount);
      };
      
      const renderCards = (items) => {
        grid.innerHTML = '';
        if (items.length === 0) {
          noResults.style.display = 'block';
          return;
        }
        noResults.style.display = 'none';
        
        items.forEach(item => {
          const card = document.createElement('div');
          card.className = 'facility-card';
          
          const ratingBlock = item.rating 
            ? `<span class="card-rating" style="display:flex; align-items:center; gap:2px; font-weight:600; font-size:0.85rem">
                 ⭐ ${item.rating.toFixed(1)}
               </span>`
            : '';
            
          const pricingBlock = item.pricingMin
            ? `<div>
                 <span class="pricing-label" style="font-size:0.75rem; color:var(--text-muted)">Starting at</span>
                 <span class="pricing-amount" style="font-size:1.15rem; font-weight:700; color:var(--primary)">${formatCost(item.pricingMin)}</span>
                 <span class="pricing-period" style="font-size:0.75rem; color:var(--text-muted)">/${item.pricingPeriod}</span>
               </div>`
            : `<span class="pricing-missing" style="font-size:0.85rem; color:var(--text-muted)">Call for rates</span>`;
            
          card.innerHTML = `
            <div class="card-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:var(--space-md); border-bottom:1px solid var(--border); padding-bottom:var(--space-xs)">
              <span class="card-location" style="font-size:0.8rem; font-weight:700; color:var(--text-muted); text-transform:uppercase">${item.city}, ${item.state.toUpperCase()}</span>
              ${ratingBlock}
            </div>
            <div class="card-body" style="display:flex; flex-direction:column; gap:var(--space-sm); flex-grow:1">
              <h3 class="card-title" style="margin:0; font-size:1.15rem">
                <a href="/parks/${item.slug}" style="color:var(--text-main); font-weight:700">${item.displayName}</a>
              </h3>
              <div class="card-pricing" style="margin-bottom:var(--space-xs)">
                ${pricingBlock}
              </div>
              
              <div class="card-signals" style="background:var(--bg-body); border:1px solid var(--border); border-radius:var(--radius-sm); padding:var(--space-xs)">
                <span class="signals-label" style="font-size:0.75rem; font-weight:700; color:var(--text-muted)">Signal Strength:</span>
                <div style="font-size:0.8rem; margin-top:2px; display:flex; gap:var(--space-md)">
                  <div>Verizon: <span style="font-weight:700" class="text-sig-${item.nicheFields.verizonSignal || 'none'}">${item.nicheFields.verizonSignal || 'unreported'}</span></div>
                  <div>T-Mobile: <span style="font-weight:700" class="text-sig-${item.nicheFields.tmobileSignal || 'none'}">${item.nicheFields.tmobileSignal || 'unreported'}</span></div>
                </div>
              </div>
              
              <div class="card-badges" style="display:flex; gap:var(--space-xs); flex-wrap:wrap">
                ${item.nicheFields.wifiAvailable ? '<span class="badge badge-success" style="background:#10b981; color:white; padding:2px 8px; border-radius:50px; font-size:0.75rem; font-weight:600">Wi-Fi</span>' : ''}
                ${item.nicheFields.starlinkFriendly ? '<span class="badge badge-primary" style="background:#3b82f6; color:white; padding:2px 8px; border-radius:50px; font-size:0.75rem; font-weight:600">Starlink OK</span>' : ''}
                ${item.nicheFields.maxRvLengthFt ? `<span class="badge badge-outline" style="border:1px solid var(--border); color:var(--text-main); padding:2px 8px; border-radius:50px; font-size:0.75rem; font-weight:600">Up to ${item.nicheFields.maxRvLengthFt}ft</span>` : ''}
              </div>
            </div>
            <div class="card-footer" style="margin-top:var(--space-lg)">
              <a href="/parks/${item.slug}" class="btn btn-outline" style="width:100%; text-align:center; display:block">Signal Report</a>
            </div>
          `;
          grid.appendChild(card);
        });
      };
      
      const filterListings = () => {
        let filtered = listings;
        
        if (filterVerizon.checked) {
          filtered = filtered.filter(item => ['strong', 'medium'].includes((item.nicheFields.verizonSignal || '').toLowerCase()));
        }
        if (filterTMobile.checked) {
          filtered = filtered.filter(item => ['strong', 'medium'].includes((item.nicheFields.tmobileSignal || '').toLowerCase()));
        }
        if (filterAtt.checked) {
          filtered = filtered.filter(item => ['strong', 'medium'].includes((item.nicheFields.attSignal || '').toLowerCase()));
        }
        if (filterWifi.checked) {
          filtered = filtered.filter(item => item.nicheFields.wifiAvailable === true);
        }
        if (filterStarlink.checked) {
          filtered = filtered.filter(item => item.nicheFields.starlinkFriendly === true);
        }
        
        renderCards(filtered);
      };
      
      [filterVerizon, filterTMobile, filterAtt, filterWifi, filterStarlink].forEach(checkbox => {
        checkbox.addEventListener('change', filterListings);
      });
      
      renderCards(listings);
    });
  </script>

  <!-- Browse Section -->
  <section id="browse" class="section browse-section">
    <div class="container">
      <h2 class="section-title">Browse Campgrounds by State</h2>
      <p class="section-subtitle">Select a state and city to view verified signal profiles, nightly rates, and maximum RV length allowances.</p>
      
      <div class="grid grid-3">
        {states.map(state => (
          <div class="state-card">
            <h3>{state.name}</h3>
            <div class="city-links">
              {state.cities.map(city => {
                const count = getCityCount(city, state.code);
                const href = `/${state.code}/${city.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
                return (
                  <a href={href} class="city-link">
                    <span class="city-name">{city}</span>
                    <span class="city-count">{count} {count === 1 ? 'listing' : 'listings'}</span>
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Section -->
  {featuredListings.length > 0 && (
    <section class="section featured-section">
      <div class="container">
        <h2 class="section-title">Top Rated Digital Nomad Campsites</h2>
        <p class="section-subtitle">Campgrounds featuring strong verified LTE/5G signals and modern office-ready Wi-Fi connections.</p>
        
        <div class="grid grid-3">
          {featuredListings.map(item => (
            <Card
              slug={item.slug}
              displayName={item.displayName}
              city={item.city}
              state={item.state}
              rating={item.rating}
              pricingMin={item.pricingMin}
              pricingPeriod={item.pricingPeriod}
              pricingNote={item.pricingNote}
              verizonSignal={item.nicheFields.verizonSignal}
              tmobileSignal={item.nicheFields.tmobileSignal}
              attSignal={item.nicheFields.attSignal}
              wifiAvailable={item.nicheFields.wifiAvailable}
              maxRvLengthFt={item.nicheFields.maxRvLengthFt}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Connectivity Specifications Section -->
  <section id="about" class="section info-section">
    <div class="container">
      <div class="info-grid">
        <div class="info-content">
          <h2>Nomad-First Signal Audits</h2>
          <p>We believe reliable internet is as essential as running water. We audit campsites using three main factors:</p>
          <ul class="info-list">
            <li>
              <strong>Carrier Signal Verification:</strong> Real strength levels for Verizon, T-Mobile, and AT&T so you know whether you need a signal booster.
            </li>
            <li>
              <strong>Starlink Obstruction:</strong> Mapping tree line cover to check if you can use your satellite dish from your site.
            </li>
            <li>
              <strong>Verified Wi-Fi Speeds:</strong> We log actual download/upload speeds on the campground's office networks.
            </li>
          </ul>
        </div>
        <div class="info-card">
          <h4>Looking for Affiliate Gear?</h4>
          <p>We link to top-rated signal boosters (WeBoost), Starlink mounts, and mobile routers to keep your rig connected anywhere.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="section faq-section">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <p class="section-subtitle">Connectivity, gear, and RV park booking details.</p>
      <FAQ items={faqItems} />
    </div>
  </section>
</Layout>

<style>
  /* Hero Styles */
  .hero {
    background: linear-gradient(135deg, var(--primary-light) 0%, hsl(120, 20%, 98%) 100%);
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .hero-container {
    min-height: 480px;
    display: flex;
    align-items: center;
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  .hero-content {
    max-width: 780px;
  }

  .hero-tag {
    display: inline-block;
    background-color: var(--primary);
    color: #ffffff;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: var(--space-md);
  }

  .hero h1 {
    font-size: 3rem;
    color: var(--text-main);
    margin-bottom: var(--space-md);
    line-height: 1.15;
  }

  .hero p {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: var(--space-xl);
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* Section Headers */
  .section-title {
    font-size: 2.2rem;
    text-align: center;
    margin-bottom: var(--space-xs);
  }

  .section-subtitle {
    text-align: center;
    color: var(--text-muted);
    margin-bottom: var(--space-2xl);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Browse Cards */
  .state-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    box-shadow: var(--shadow-sm);
  }

  .state-card h3 {
    font-size: 1.35rem;
    margin-bottom: var(--space-lg);
    color: var(--primary);
    border-bottom: 2px solid var(--primary-light);
    padding-bottom: var(--space-xs);
  }

  .city-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .city-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm);
    border-radius: var(--radius-sm);
    background-color: var(--bg-page);
    border: 1px solid transparent;
  }

  .city-link:hover {
    border-color: var(--primary);
    background-color: var(--primary-light);
  }

  .city-name {
    font-weight: 600;
    color: var(--text-main);
  }

  .city-count {
    font-size: 0.8rem;
    color: var(--text-muted);
    background-color: var(--bg-card);
    padding: 2px 8px;
    border-radius: 50px;
    border: 1px solid var(--border);
  }

  /* Info Section */
  .info-section {
    background-color: var(--secondary);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .info-grid {
    display: grid;
    gap: var(--space-2xl);
    grid-template-columns: 1fr;
  }

  @media (min-width: 900px) {
    .info-grid {
      grid-template-columns: 2fr 1fr;
    }
  }

  .info-content h2 {
    font-size: 2rem;
    margin-bottom: var(--space-md);
  }

  .info-list {
    list-style: none;
    margin-top: var(--space-md);
  }

  .info-list li {
    margin-bottom: var(--space-md);
    position: relative;
    padding-left: var(--space-xl);
  }

  .info-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 2px;
    color: var(--accent);
    font-weight: 800;
    font-size: 1.1rem;
  }

  .info-card {
    background-color: var(--primary);
    color: #ffffff;
    padding: var(--space-xl);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .info-card h4 {
    color: #ffffff;
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
  }

  .info-card p {
    color: var(--primary-light);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  @media (max-width: 600px) {
    .hero h1 {
      font-size: 2.25rem;
    }
  }

  /* Filter Dashboard Styles */
  .filter-controls {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    margin-bottom: var(--space-lg);
    box-shadow: var(--shadow-sm);
  }
  @media (min-width: 768px) {
    .filter-controls {
      grid-template-columns: 1fr 1fr;
    }
  }
  .filter-group h5 {
    margin-top: 0;
    margin-bottom: var(--space-sm);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--primary);
  }
  .checkbox-row {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }
  .checkbox-row label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    cursor: pointer;
  }
  .checkbox-row input[type="checkbox"] {
    width: 16px;
    height: 16px;
    cursor: pointer;
  }
  .text-sig-strong { color: var(--text-success); }
  .text-sig-medium { color: #d97706; }
  .text-sig-weak { color: #dc2626; }
  .text-sig-none { color: var(--text-secondary); }
</style>
