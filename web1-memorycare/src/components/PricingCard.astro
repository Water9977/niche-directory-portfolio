---
interface Props {
  pricingMin: number | null;
  pricingMax: number | null;
  pricingPeriod: string;
  pricingNote: string | null;
  sourceSnippet: string | null;
}

const { pricingMin, pricingMax, pricingPeriod, pricingNote, sourceSnippet } = Astro.props;

// Formatting helper
const formatCost = (cost: number) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    maximumFractionDigits: 0
  }).format(cost);
};
---

<div class="pricing-card">
  <div class="pricing-header">
    <h3>Cost Estimation</h3>
  </div>
  
  <div class="pricing-body">
    {pricingMin ? (
      <div class="pricing-display">
        <div class="price-value">
          {formatCost(pricingMin)}
          {pricingMax && ` – ${formatCost(pricingMax)}`}
        </div>
        <div class="price-period">per {pricingPeriod}</div>
      </div>
    ) : (
      <div class="pricing-missing">
        <p>Direct pricing details are not publicly listed on their website.</p>
      </div>
    )}

    {pricingNote && (
      <p class="pricing-note">
        <strong>Note:</strong> {pricingNote}
      </p>
    )}

    {sourceSnippet && (
      <div class="pricing-source">
        <span class="source-label">Source citation from website:</span>
        <blockquote class="source-quote">
          "{sourceSnippet}"
        </blockquote>
      </div>
    )}
  </div>
</div>

<style>
  .pricing-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    margin-bottom: var(--space-lg);
  }

  .pricing-header {
    background-color: var(--primary-light);
    border-bottom: 1px solid var(--border);
    padding: var(--space-md) var(--space-lg);
  }

  .pricing-header h3 {
    color: var(--primary);
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .pricing-body {
    padding: var(--space-lg);
  }

  .pricing-display {
    margin-bottom: var(--space-md);
  }

  .price-value {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--primary);
    line-height: 1.1;
  }

  .price-period {
    font-size: 0.95rem;
    color: var(--text-muted);
    font-weight: 500;
    margin-top: 2px;
  }

  .pricing-note {
    font-size: 0.9rem;
    color: var(--text-muted);
    background-color: var(--secondary);
    padding: var(--space-sm);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-lg);
    border-left: 3px solid var(--primary);
  }

  .pricing-source {
    border-top: 1px solid var(--border);
    padding-top: var(--space-md);
  }

  .source-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
  }

  .source-quote {
    font-size: 0.95rem;
    font-style: italic;
    color: var(--text-main);
    border-left: 3px solid var(--accent);
    padding-left: var(--space-md);
    margin-left: 0;
  }
</style>
